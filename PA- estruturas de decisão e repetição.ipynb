        "# Programa para identificar se um número é par ou ímpar\n",
        "numero = int(input(\"Digite um número: \"))\n",
        "if numero % 2 == 0:\n",
        "    print(\"O número é par\")\n",
        "else:\n",
        "    print(\"O número é ímpar\")\n",
        "\n",
        "# Programa para contar de 1 até 10\n",
        "for i in range(1, 11):\n",
        "    print(i)"
